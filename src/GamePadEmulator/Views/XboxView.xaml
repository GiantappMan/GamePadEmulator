<UserControl x:Class="GamePadEmulator.Views.XboxView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:GamePadEmulator.Controls"
             Background="Transparent"
             PreviewMouseDown="Btn_PreviewDown" PreviewMouseUp="Btn_PreviewUp">

    <!-- 写实拟物 Xbox 360。交互元素 Tag 由代码后置消费；机身纯装饰矢量。
         Grid 保持 760×480 不变（元素绝对定位依赖它），用 ScaleTransform 把内容等比
         放大（保留适度边距，不贴边），消除大部分留白。元素相对位置完全不变。-->
    <Viewbox Stretch="Uniform">
        <Grid Width="760" Height="480" RenderTransformOrigin="0.5,0.481">
            <Grid.RenderTransform>
                <ScaleTransform ScaleX="1.50" ScaleY="1.50"/>
            </Grid.RenderTransform>

            <!-- ============ 机身（Xbox 360 轮廓）============ -->
            <!-- 阴影底 -->
            <Path Fill="#000000" Opacity="0.4" Margin="0,6,0,-4">
                <Path.Effect><BlurEffect Radius="10"/></Path.Effect>
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="300,150" IsClosed="True">
                            <BezierSegment Point1="345,140" Point2="415,140" Point3="460,150"/>
                            <BezierSegment Point1="505,158" Point2="555,185" Point3="585,245"/>
                            <BezierSegment Point1="610,310" Point2="555,375" Point3="490,360"/>
                            <BezierSegment Point1="450,352" Point2="430,335" Point3="410,335"/>
                            <LineSegment Point="350,335"/>
                            <BezierSegment Point1="330,335" Point2="310,352" Point3="270,360"/>
                            <BezierSegment Point1="205,375" Point2="150,310" Point3="175,245"/>
                            <BezierSegment Point1="205,185" Point2="255,158" Point3="300,150"/>
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>
            <!-- 主体填充渐变 -->
            <Path Fill="{StaticResource BodyFill}" Stroke="#0A0A10" StrokeThickness="2">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="300,150" IsClosed="True">
                            <BezierSegment Point1="345,140" Point2="415,140" Point3="460,150"/>
                            <BezierSegment Point1="505,158" Point2="555,185" Point3="585,245"/>
                            <BezierSegment Point1="610,310" Point2="555,375" Point3="490,360"/>
                            <BezierSegment Point1="450,352" Point2="430,335" Point3="410,335"/>
                            <LineSegment Point="350,335"/>
                            <BezierSegment Point1="330,335" Point2="310,352" Point3="270,360"/>
                            <BezierSegment Point1="205,375" Point2="150,310" Point3="175,245"/>
                            <BezierSegment Point1="205,185" Point2="255,158" Point3="300,150"/>
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>
            <!-- 表面高光层 -->
            <Path Fill="{StaticResource BodyGloss}" IsHitTestVisible="False">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="300,150" IsClosed="True">
                            <BezierSegment Point1="345,140" Point2="415,140" Point3="460,150"/>
                            <BezierSegment Point1="505,158" Point2="555,185" Point3="585,245"/>
                            <BezierSegment Point1="610,310" Point2="555,375" Point3="490,360"/>
                            <BezierSegment Point1="450,352" Point2="430,335" Point3="410,335"/>
                            <LineSegment Point="350,335"/>
                            <BezierSegment Point1="330,335" Point2="310,352" Point3="270,360"/>
                            <BezierSegment Point1="205,375" Point2="150,310" Point3="175,245"/>
                            <BezierSegment Point1="205,185" Point2="255,158" Point3="300,150"/>
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>

            <!-- ============ Guide 中央圆环（凹陷盘）============ -->
            <Ellipse Width="82" Height="82" Fill="#0A0A10" Stroke="#2A2A34" StrokeThickness="1.5"
                     HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,180,0,0" IsHitTestVisible="False">
                <Ellipse.Effect><DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="3" Opacity="0.7"/></Ellipse.Effect>
            </Ellipse>
            <!-- 圆环描边（Xbox 同心圆）-->
            <Ellipse Width="82" Height="82" Stroke="#3A3A48" StrokeThickness="1" Opacity="0.6"
                     HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,180,0,0" IsHitTestVisible="False"/>
            <Ellipse Width="58" Height="58" Stroke="#2A2A34" StrokeThickness="1"
                     HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,192,0,0" IsHitTestVisible="False"/>

            <!-- ============ 扣机 LT / RT（紧贴机身顶部边缘，消除上方空白）============ -->
            <ctrl:TriggerBar x:Name="LeftTrigger" Tag="LT"
                             HorizontalAlignment="Left" VerticalAlignment="Top" Margin="190,112,0,0"
                             ValueChanged="LeftTrigger_Changed"/>
            <ctrl:TriggerBar x:Name="RightTrigger" Tag="RT"
                             HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,112,190,0"
                             ValueChanged="RightTrigger_Changed"/>

            <!-- ============ 肩键 LB / RB（紧贴扣机下方，消除中间空白）============ -->
            <Border Tag="LB" CornerRadius="14" Width="92" Height="22" Background="{StaticResource ShoulderFill}"
                    BorderBrush="#40404A" BorderThickness="1.5"
                    HorizontalAlignment="Left" VerticalAlignment="Top" Margin="190,87,0,0" Cursor="Hand">
                <Border.Effect><DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="2" Opacity="0.5"/></Border.Effect>
                <TextBlock Text="LB" Foreground="#CFCFD8" FontSize="12" FontWeight="SemiBold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <Border Tag="RB" CornerRadius="14" Width="92" Height="22" Background="{StaticResource ShoulderFill}"
                    BorderBrush="#40404A" BorderThickness="1.5"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,87,190,0" Cursor="Hand">
                <Border.Effect><DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="2" Opacity="0.5"/></Border.Effect>
                <TextBlock Text="RB" Foreground="#CFCFD8" FontSize="12" FontWeight="SemiBold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- ============ 面键（右上：Y B A X）============ -->
            <Grid Width="128" Height="128" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,158,180,0">
                <!-- Y（上）-->
                <Button Tag="Y" Style="{StaticResource PadButton}" Background="#1E1E26" BorderBrush="{StaticResource Xbox_Y}"
                        Width="44" Height="44" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,2,0,0">
                    <TextBlock Text="Y" Foreground="{StaticResource Xbox_Y}" FontWeight="Bold" FontSize="20"/>
                </Button>
                <!-- B（右）-->
                <Button Tag="B" Style="{StaticResource PadButton}" Background="#1E1E26" BorderBrush="{StaticResource Xbox_B}"
                        Width="44" Height="44" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,2,0">
                    <TextBlock Text="B" Foreground="{StaticResource Xbox_B}" FontWeight="Bold" FontSize="20"/>
                </Button>
                <!-- A（下）-->
                <Button Tag="A" Style="{StaticResource PadButton}" Background="#1E1E26" BorderBrush="{StaticResource Xbox_A}"
                        Width="44" Height="44" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,2">
                    <TextBlock Text="A" Foreground="{StaticResource Xbox_A}" FontWeight="Bold" FontSize="20"/>
                </Button>
                <!-- X（左）-->
                <Button Tag="X" Style="{StaticResource PadButton}" Background="#1E1E26" BorderBrush="{StaticResource Xbox_X}"
                        Width="44" Height="44" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="2,0,0,0">
                    <TextBlock Text="X" Foreground="{StaticResource Xbox_X}" FontWeight="Bold" FontSize="20"/>
                </Button>
            </Grid>

            <!-- ============ 左摇杆（左上）============ -->
            <ctrl:AnalogStick x:Name="LeftStick" Tag="L3" TravelRadius="32"
                              HorizontalAlignment="Left" VerticalAlignment="Top" Margin="188,160,0,0"
                              PositionChanged="LeftStick_Changed"/>

            <!-- ============ 十字键（左摇杆右下方，对角 —— 修正 X360 标准位置）============ -->
            <Grid Width="116" Height="116" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="-90,250,0,0">
                <!-- 凹盘底 -->
                <Ellipse Fill="#0C0C12" Stroke="#2A2A34" StrokeThickness="1.5">
                    <Ellipse.Effect><DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="2" Opacity="0.6"/></Ellipse.Effect>
                </Ellipse>
                <!-- 十字 -->
                <Path Stroke="#0E0E14" StrokeThickness="1.5">
                    <Path.Fill>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Offset="0" Color="#34343E"/>
                            <GradientStop Offset="1" Color="#1C1C24"/>
                        </LinearGradientBrush>
                    </Path.Fill>
                    <Path.Data>M40,6 L76,6 L76,40 L110,40 L110,76 L76,76 L76,110 L40,110 L40,76 L6,76 L6,40 L40,40 Z</Path.Data>
                </Path>
                <!-- 中心圆点 -->
                <Ellipse Width="10" Height="10" Fill="#0C0C12" Stroke="#2C2C36" StrokeThickness="1" IsHitTestVisible="False"/>
                <!-- 上 -->
                <Border Tag="Up" Background="Transparent" Width="40" Height="36" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,8,0,0" Cursor="Hand">
                    <Path Data="M0,22 L18,5 L36,22 Z" Fill="#3A3A48" Stretch="Uniform" Width="20" Height="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <!-- 下 -->
                <Border Tag="Down" Background="Transparent" Width="40" Height="36" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,8" Cursor="Hand">
                    <Path Data="M0,5 L18,22 L36,5 Z" Fill="#3A3A48" Stretch="Uniform" Width="20" Height="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <!-- 左 -->
                <Border Tag="Left" Background="Transparent" Width="36" Height="40" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,0,0,0" Cursor="Hand">
                    <Path Data="M22,0 L5,18 L22,36 Z" Fill="#3A3A48" Stretch="Uniform" Width="13" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <!-- 右 -->
                <Border Tag="Right" Background="Transparent" Width="36" Height="40" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0" Cursor="Hand">
                    <Path Data="M5,0 L22,18 L5,36 Z" Fill="#3A3A48" Stretch="Uniform" Width="13" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- ============ 右摇杆（右下）============ -->
            <ctrl:AnalogStick x:Name="RightStick" Tag="R3" TravelRadius="32"
                              HorizontalAlignment="Center" VerticalAlignment="Top" Margin="90,262,0,0"
                              PositionChanged="RightStick_Changed"/>

            <!-- ============ Back / Start（Guide 两侧）============ -->
            <Border Tag="Back" CornerRadius="9" Width="32" Height="16" Background="#1E1E26" BorderBrush="#3A3A44" BorderThickness="1"
                    HorizontalAlignment="Center" VerticalAlignment="Top" Margin="-52,210,0,0" Cursor="Hand">
                <TextBlock Text="◀▶" Foreground="#7A7A88" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <Border Tag="Start" CornerRadius="9" Width="32" Height="16" Background="#1E1E26" BorderBrush="#3A3A44" BorderThickness="1"
                    HorizontalAlignment="Center" VerticalAlignment="Top" Margin="52,210,0,0" Cursor="Hand">
                <TextBlock Text="▶|◀" Foreground="#7A7A88" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- ============ Guide 按钮（中央，Xbox 发光绿球）============ -->
            <Border Tag="Guide" CornerRadius="20" Width="40" Height="40"
                    BorderBrush="#3FAF3F" BorderThickness="2"
                    HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,200,0,0" Cursor="Hand">
                <Border.Effect>
                    <DropShadowEffect Color="#3FAF3F" BlurRadius="16" ShadowDepth="0" Opacity="0.75"/>
                </Border.Effect>
                <Border.Background>
                    <RadialGradientBrush GradientOrigin="0.4,0.3">
                        <GradientStop Offset="0" Color="#2FAE2F"/>
                        <GradientStop Offset="0.7" Color="#107C10"/>
                        <GradientStop Offset="1" Color="#0A5A0A"/>
                    </RadialGradientBrush>
                </Border.Background>
                <TextBlock Text="X" Foreground="White" FontWeight="Bold" FontSize="22"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

        </Grid>
    </Viewbox>
</UserControl>
